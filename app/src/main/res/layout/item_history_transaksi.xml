<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="2dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaksi #12 • PS A01"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#111827" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="1 sewa • 2 produk"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="12 Apr 2026"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvStatusTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#EDE9FE"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="aktif"
                android:textColor="#6D28D9"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvStatusBayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="#FEF3C7"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="menunggu"
                android:textColor="#B45309"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Rp10.000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#2563EB" />
    </LinearLayout>
</androidx.cardview.widget.CardView>